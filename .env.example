# Credenciais do app (obtidas no painel da Appmax)
APP_CLIENT_ID=seu_client_id
APP_CLIENT_SECRET=seu_client_secret
APP_ID=seu_app_id

# Chave externa que identifica a instalação no seu sistema
APP_EXTERNAL_KEY=teste-local-001

# URL pública (ngrok) que recebe o callback de instalação
CALLBACK_URL=https://seu-dominio.ngrok-free.dev/callback/install

# Base da loja para onde o merchant é redirecionado (com barra no final)
STORE_INTEGRATION_URL=https://sua-loja.exemplo.com.br/appstore/integration/

# Endpoints da Appmax (sandbox por padrão)
API_BASE_URL=https://api.sandboxappmax.com.br
AUTH_URL=https://auth.sandboxappmax.com.br/oauth2/token

# Porta do servidor local
PORT=8080
